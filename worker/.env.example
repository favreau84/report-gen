# Worker env - copier vers .env et remplir
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# "Secret key" (Settings → API Keys → Publishable and secret API keys)
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxx
# Optionnel : seulement pour vérifier les anciens tokens HS256 (legacy).
# Sans cette valeur, le worker vérifie les JWT via JWKS (ES256/RS256) — c'est le mode standard.
# SUPABASE_JWT_SECRET=
# Origines autorisées pour CORS (séparées par virgule)
CORS_ORIGINS=http://localhost:5173
# Chemin du binaire LibreOffice
SOFFICE_BIN=soffice
