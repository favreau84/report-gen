{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "web",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "web", "run", "dev"],
      "port": 5173
    },
    {
      "name": "worker",
      "runtimeExecutable": "bash",
      "runtimeArgs": [
        "-lc",
        "cd worker && .venv/bin/uvicorn app.server:app --port 8080 --reload"
      ],
      "port": 8080
    }
  ]
}
